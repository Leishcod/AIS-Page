---
import Layout from "../layouts/Layout.astro";
import heroBg from "../assets/hero-bg.png";
import logoHorizontal from "../assets/logo_horizontal.webp";
---

<Layout
	title="AIS | Artificial Intelligence Society"
	description="Liderando la vanguardia científica de la inteligencia artificial en el Perú."
>
	<!-- Header -->
	<header
		class="sticky top-0 z-50 bg-[#0B0F19]/80 backdrop-blur-md border-b border-gray-800/60 transition-all duration-300"
	>
		<div
			class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between"
		>
			<!-- Logo -->
			<a href="/">
				<img
					src={logoHorizontal.src}
					alt="Artificial Intelligence Society Logo"
					class="h-10 object-contain"
				/>
			</a>

			<!-- Navigation (Without 'Inicio' link as requested) -->
			<nav
				class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-300"
			>
				<a
					href="/areas"
					class="hover:text-white pb-1 px-1 transition-colors"
					>Áreas</a
				>
				<a
					href="/projects"
					class="hover:text-white pb-1 px-1 transition-colors"
					>Proyectos</a
				>
				<a
					href="/call"
					class="hover:text-white pb-1 px-1 transition-colors"
					>Convocatorias</a
				>
			</nav>

			<!-- CTA Button -->
			<a
				href="/call"
				class="relative inline-flex items-center justify-center p-0.5 overflow-hidden text-xs font-semibold text-white rounded-lg group bg-gradient-to-br from-blue-600 to-cyan-500 group-hover:from-blue-600 group-hover:to-cyan-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-800 transition-all duration-300"
			>
				<span
					class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-[#0B0F19] rounded-md group-hover:bg-opacity-0"
				>
					Únete a AIS
				</span>
			</a>
		</div>
	</header>

	<main class="relative overflow-hidden">
		<!-- Background Glows -->
		<div
			class="absolute top-1/4 left-1/10 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl -z-10 animate-pulse duration-[6s]"
		>
		</div>
		<div
			class="absolute top-1/2 right-1/10 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl -z-10 animate-pulse duration-[8s]"
		>
		</div>

		<!-- Hero Section -->
		<section
			class="relative min-h-[85vh] flex items-center py-20 lg:py-32 overflow-hidden border-b border-gray-900"
		>
			<!-- Background Image with Overlay -->
			<div class="absolute inset-0 z-0">
				<img
					src={heroBg.src}
					alt="Workspace background"
					class="w-full h-full object-cover opacity-25"
				/>
				<div
					class="absolute inset-0 bg-gradient-to-b from-[#0B0F19]/90 via-[#0B0F19]/80 to-[#0B0F19]"
				>
				</div>
			</div>

			<div class="max-w-7xl mx-auto px-6 relative z-10 w-full">
				<div class="max-w-4xl space-y-6">
					<h1
						class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight"
					>
						Liderando el avance de la <span
							class="italic font-serif text-blue-400">IA</span
						>
					</h1>
					<p
						class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-3xl"
					>
						AIS (Artificial Intelligence Society) es una
						organización profesional, científica y técnica
						constituida como el organismo regulador y de
						convergencia para profesionales, investigadores,
						ingenieros y académicos en el campo de la Inteligencia
						Artificial.
					</p>
					<div class="flex flex-wrap gap-4 pt-4">
						<a
							href="#about"
							class="px-8 py-3.5 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all shadow-lg shadow-blue-500/20 transform hover:-translate-y-0.5"
						>
							Conócenos
						</a>
						<a
							href="/call"
							class="px-8 py-3.5 text-sm font-bold text-gray-300 border border-gray-700 rounded-xl hover:text-white hover:border-gray-500 transition-all backdrop-blur-sm"
						>
							Ver Convocatorias
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Statistics Counter Banner -->
		<section
			class="border-b border-gray-800/60 bg-gray-950/40 backdrop-blur-sm py-12 relative z-10"
		>
			<div
				class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center"
			>
				<div class="space-y-1">
					<div
						class="text-4xl font-extrabold text-white tracking-tight"
					>
						500+
					</div>
					<div
						class="text-[10px] md:text-xs font-bold tracking-widest text-gray-400 uppercase"
					>
						Miembros Activos
					</div>
				</div>
				<div class="space-y-1">
					<div
						class="text-4xl font-extrabold text-white tracking-tight"
					>
						48+
					</div>
					<div
						class="text-[10px] md:text-xs font-bold tracking-widest text-gray-400 uppercase"
					>
						Proyectos Completados
					</div>
				</div>
				<div class="space-y-1">
					<div
						class="text-4xl font-extrabold text-white tracking-tight"
					>
						15+
					</div>
					<div
						class="text-[10px] md:text-xs font-bold tracking-widest text-gray-400 uppercase"
					>
						Eventos Anuales
					</div>
				</div>
				<div class="space-y-1">
					<div
						class="text-4xl font-extrabold text-white tracking-tight"
					>
						5+
					</div>
					<div
						class="text-[10px] md:text-xs font-bold tracking-widest text-gray-400 uppercase"
					>
						Áreas de Investigación
					</div>
				</div>
			</div>
		</section>

		<!-- Misión & Visión Section -->
		<section
			id="about"
			class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-2 gap-12 border-t border-gray-800/40"
		>
			<!-- Misión Panel -->
			<div
				class="p-8 md:p-12 rounded-3xl bg-gray-900/10 border border-gray-800/80 backdrop-blur-md flex flex-col justify-between hover:border-blue-500/20 transition-all duration-300"
			>
				<div>
					<div
						class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-8"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-6 w-6"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold text-white mb-6">
						Misión
					</h3>
					<p class="text-gray-300 leading-relaxed text-base">
						Liderar el avance global de la inteligencia artificial y
						la competencia de sus profesionales; conectando a la
						comunidad para intercambiar conocimientos técnicos,
						establecer los más altos estándares éticos y
						científicos, y garantizar que la tecnología se
						desarrolle para el beneficio, bienestar y equidad de la
						humanidad.
					</p>
				</div>
			</div>

			<!-- Visión Panel -->
			<div
				class="p-8 md:p-12 rounded-3xl bg-gray-900/10 border border-gray-800/80 backdrop-blur-md flex flex-col justify-between hover:border-cyan-500/20 transition-all duration-300"
			>
				<div>
					<div
						class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 mb-8"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-6 w-6"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
							></path>
						</svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold text-white mb-6">
						Visión
					</h3>
					<p class="text-gray-300 leading-relaxed text-base">
						Ser reconocida como una organización profesional de
						referencia en inteligencia artificial, estableciendo
						altos estándares de práctica, investigación y ética en
						el campo, con especial vocación de servicio en el Perú
						y, conforme crezca de manera sostenida, en América
						Latina y el mundo en desarrollo.
					</p>
				</div>
			</div>
		</section>

		<!-- Proyectos Destacados Section -->
		<section
			class="max-w-7xl mx-auto px-6 py-20 border-t border-gray-800/40"
		>
			<div
				class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4"
			>
				<div>
					<span
						class="text-xs font-bold tracking-widest text-blue-400 uppercase"
						>Trabajo Científico</span
					>
					<h2
						class="text-3xl md:text-4xl font-extrabold text-white mt-2"
					>
						Proyectos Destacados
					</h2>
				</div>
				<a
					href="/projects"
					class="inline-flex items-center gap-2 text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors"
				>
					Ver todos los proyectos
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M9 5l7 7-7 7"></path>
					</svg>
				</a>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
				<!-- Project 1 (Large Grid - spans 2 columns on lg) -->
				<div
					class="lg:col-span-2 p-8 md:p-10 rounded-3xl bg-[#0F1423]/30 border border-gray-800/80 backdrop-blur-md group hover:border-blue-500/30 transition-all duration-300 flex flex-col justify-between"
				>
					<div>
						<span
							class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-400 mb-6"
							>Machine Learning</span
						>
						<h3
							class="text-2xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors"
						>
							Neural Odyssey: Optimización Industrial
						</h3>
						<p
							class="text-gray-400 leading-relaxed text-sm max-w-xl"
						>
							Implementación de arquitectura Transformer para la
							optimización de procesos de manufactura, permitiendo
							un 28% más de eficiencia en plantas automatizadas.
						</p>
					</div>
					<div
						class="mt-8 pt-6 border-t border-gray-850 flex items-center justify-between"
					>
						<span class="text-xs text-gray-500"
							>Publicado: Enero 2026</span
						>
						<a
							href="/projects"
							class="text-xs font-bold text-white group-hover:underline"
							>Leer Caso de Estudio →</a
						>
					</div>
				</div>

				<!-- Small Projects Column -->
				<div class="flex flex-col gap-6">
					<!-- Small Project 1 -->
					<div
						class="p-6 rounded-2xl bg-[#0F1423]/25 border border-gray-800/80 hover:border-blue-500/20 transition-all duration-300"
					>
						<h4 class="text-base font-bold text-white mb-2">
							Framework Ético 1.0
						</h4>
						<p class="text-gray-400 text-xs leading-relaxed">
							Lineamientos de gobernanza para el desarrollo
							responsable de la inteligencia artificial.
						</p>
					</div>

					<!-- Small Project 2 -->
					<div
						class="p-6 rounded-2xl bg-[#0F1423]/25 border border-gray-800/80 hover:border-blue-500/20 transition-all duration-300"
					>
						<h4 class="text-base font-bold text-white mb-2">
							IA en Salud Pública
						</h4>
						<p class="text-gray-400 text-xs leading-relaxed">
							Modelos de detección temprana de anomalías
							pulmonares en imágenes médicas utilizando CNNs.
						</p>
					</div>

					<!-- Small Project 3 -->
					<div
						class="p-6 rounded-2xl bg-[#0F1423]/25 border border-gray-800/80 hover:border-blue-500/20 transition-all duration-300"
					>
						<h4 class="text-base font-bold text-white mb-2">
							Uso de Redes Clónicas
						</h4>
						<p class="text-gray-400 text-xs leading-relaxed">
							Investigación de transferencia de aprendizaje para
							optimizar modelos de lenguaje en español.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Membership Request Form Section -->
		<section
			class="max-w-7xl mx-auto px-6 py-20 border-t border-gray-800/40"
		>
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Form Left Text -->
				<div class="lg:col-span-6 space-y-6">
					<span
						class="text-xs font-bold tracking-widest text-cyan-400 uppercase"
						>Convocatoria Activa</span
					>
					<h2 class="text-3xl md:text-4xl font-extrabold text-white">
						Forma parte de la élite de la IA.
					</h2>
					<p class="text-gray-300 leading-relaxed">
						Buscamos mentes brillantes apasionadas por la tecnología
						y la ética. Al unirte a AIS, accedes a recursos de
						primer nivel, mentorías exclusivas y la oportunidad de
						trabajar en proyectos de impacto global.
					</p>

					<!-- Bullet list from screenshot -->
					<ul class="space-y-3 pt-2 text-sm text-gray-300">
						<li class="flex items-center gap-3">
							<svg
								class="h-5 w-5 text-blue-400 flex-shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2.5"
									d="M5 13l4 4L19 7"></path>
							</svg>
							Acceso a laboratorios de cómputo GPU
						</li>
						<li class="flex items-center gap-3">
							<svg
								class="h-5 w-5 text-blue-400 flex-shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2.5"
									d="M5 13l4 4L19 7"></path>
							</svg>
							Networking con líderes internacionales
						</li>
						<li class="flex items-center gap-3">
							<svg
								class="h-5 w-5 text-blue-400 flex-shrink-0"
								fill="none"
								viewBox="0 0 24 24"
								stroke="currentColor"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2.5"
									d="M5 13l4 4L19 7"></path>
							</svg>
							Certificaciones internacionales avaladas
						</li>
					</ul>
				</div>

				<!-- Form Right Card -->
				<div class="lg:col-span-6">
					<div
						class="p-8 rounded-3xl bg-[#0F1423]/40 border border-gray-800/80 backdrop-blur-md shadow-2xl"
					>
						<h3 class="text-xl font-bold text-white mb-6">
							Solicitud de Membresía
						</h3>
						<form class="space-y-4">
							<div>
								<label
									class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"
									>Nombre Completo</label
								>
								<input
									type="text"
									placeholder="Tu nombre"
									class="w-full px-4 py-3 rounded-xl bg-gray-950/60 border border-gray-800 text-white placeholder-gray-600 focus:outline-none focus:border-blue-500 text-sm transition-all"
								/>
							</div>
							<div>
								<label
									class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"
									>Email</label
								>
								<input
									type="email"
									placeholder="tu@email.com"
									class="w-full px-4 py-3 rounded-xl bg-gray-950/60 border border-gray-800 text-white placeholder-gray-600 focus:outline-none focus:border-blue-500 text-sm transition-all"
								/>
							</div>
							<div>
								<label
									class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"
									>Área de interés</label
								>
								<select
									class="w-full px-4 py-3 rounded-xl bg-gray-950/60 border border-gray-800 text-white focus:outline-none focus:border-blue-500 text-sm transition-all"
								>
									<option
										value=""
										disabled
										selected
										class="bg-gray-950 text-gray-500"
										>Seleccione un área</option
									>
									<option
										value="research"
										class="bg-gray-950 text-white"
										>Investigación e Innovación</option
									>
									<option
										value="ethics"
										class="bg-gray-950 text-white"
										>Ética y Gobernanza</option
									>
									<option
										value="education"
										class="bg-gray-950 text-white"
										>Educación y Capacitación</option
									>
								</select>
							</div>
							<div>
								<label
									class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2"
									>¿Por qué te unes?</label
								>
								<textarea
									rows="3"
									placeholder="Cuéntanos sobre tu motivación..."
									class="w-full px-4 py-3 rounded-xl bg-gray-950/60 border border-gray-800 text-white placeholder-gray-600 focus:outline-none focus:border-blue-500 text-sm transition-all resize-none"
								></textarea>
							</div>
							<button
								type="submit"
								class="w-full py-3.5 text-sm font-bold text-[#0B0F19] bg-gradient-to-r from-blue-400 to-cyan-300 hover:from-blue-500 hover:to-cyan-400 rounded-xl transition-all shadow-lg shadow-blue-500/10 transform hover:scale-[1.01]"
							>
								Enviar Solicitud
							</button>
						</form>
					</div>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="bg-gray-950/80 border-t border-gray-900/60 py-16">
		<div
			class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 text-sm text-gray-400"
		>
			<!-- Column 1 -->
			<div class="space-y-4">
				<div class="flex items-center gap-3">
					<img
						src={logoHorizontal.src}
						alt="AIS Logo"
						class="h-8 object-contain"
					/>
				</div>
				<p class="leading-relaxed">
					Impulsando la frontera de la Inteligencia Artificial a
					través de la investigación rigurosa, la práctica ética y la
					colaboración interdisciplinaria.
				</p>
			</div>

			<!-- Column 2 -->
			<div class="space-y-4">
				<span
					class="font-semibold text-white uppercase tracking-wider text-xs"
					>Organización</span
				>
				<ul class="space-y-2">
					<li>
						<a
							href="/areas"
							class="hover:text-white transition-colors">Áreas</a
						>
					</li>
					<li>
						<a
							href="/projects"
							class="hover:text-white transition-colors"
							>Proyectos</a
						>
					</li>
					<li>
						<a
							href="/call"
							class="hover:text-white transition-colors"
							>Convocatorias</a
						>
					</li>
				</ul>
			</div>

			<!-- Column 3 -->
			<div class="space-y-4">
				<span
					class="font-semibold text-white uppercase tracking-wider text-xs"
					>Recursos</span
				>
				<ul class="space-y-2">
					<li>
						<a
							href="/privacy"
							class="hover:text-white transition-colors"
							>Políticas de Privacidad</a
						>
					</li>
					<li>
						<a
							href="/terms"
							class="hover:text-white transition-colors"
							>Términos de Servicio</a
						>
					</li>
				</ul>
			</div>

			<!-- Column 4 (Newsletter like in screenshot) -->
			<div class="space-y-4">
				<span
					class="font-semibold text-white uppercase tracking-wider text-xs"
					>Mantente al Día</span
				>
				<p class="text-xs">
					Suscríbete a nuestro boletín para recibir publicaciones
					científicas y noticias.
				</p>
				<form class="flex gap-2">
					<input
						type="email"
						placeholder="tu@email.com"
						class="px-3 py-2 rounded-lg bg-gray-900 border border-gray-800 text-white placeholder-gray-600 focus:outline-none focus:border-blue-500 text-xs w-full"
					/>
					<button
						class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors flex items-center justify-center"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-4 w-4"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
						</svg>
