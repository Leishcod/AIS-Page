---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AIS | Artificial Intelligence Society" description="Liderando la vanguardia científica de la inteligencia artificial en el Perú.">
	
	<!-- Header -->
	<header class="sticky top-0 z-50 bg-[#0B0F19]/80 backdrop-blur-md border-b border-gray-800/60 transition-all duration-300">
		<div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
			<!-- Logo -->
			<a href="/" class="flex items-center gap-3 group">
				<div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-blue-600 to-cyan-400 flex items-center justify-center font-bold text-white shadow-lg shadow-blue-500/20 group-hover:scale-105 transition-transform duration-300">
					AI
				</div>
				<span class="font-semibold text-lg tracking-wider text-white group-hover:text-blue-400 transition-colors duration-300">
					Artificial Intelligence Society
				</span>
			</a>

			<!-- Navigation -->
			<nav class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-300">
				<a href="/" class="text-white border-b-2 border-blue-500 pb-1 px-1 transition-all">Inicio</a>
				<a href="/areas" class="hover:text-white pb-1 px-1 transition-colors">Áreas</a>
				<a href="/projects" class="hover:text-white pb-1 px-1 transition-colors">Proyectos</a>
				<a href="/call" class="hover:text-white pb-1 px-1 transition-colors">Convocatorias</a>
			</nav>

			<!-- CTA Button -->
			<a href="/call" class="relative inline-flex items-center justify-center p-0.5 mb-2 me-2 overflow-hidden text-xs font-semibold text-white rounded-lg group bg-gradient-to-br from-blue-600 to-cyan-500 group-hover:from-blue-600 group-hover:to-cyan-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-800 transition-all duration-300 mt-2">
				<span class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-[#0B0F19] rounded-md group-hover:bg-opacity-0">
					Únete a AIS
				</span>
			</a>
		</div>
	</header>

	<main class="relative overflow-hidden">
		<!-- Background Glows -->
		<div class="absolute top-1/4 left-1/10 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl -z-10 animate-pulse duration-[6s]"></div>
		<div class="absolute top-1/2 right-1/10 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl -z-10 animate-pulse duration-[8s]"></div>

		<!-- Hero Section -->
		<section class="max-w-7xl mx-auto px-6 py-20 lg:py-32 grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
			<!-- Hero Left -->
			<div class="lg:col-span-7 flex flex-col space-y-6">
				<span class="text-xs font-bold tracking-widest text-cyan-400 uppercase">Nuestra Identidad</span>
				<h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight tracking-tight">
					Liderando la vanguardia científica en el Perú.
				</h1>
				<p class="text-gray-400 text-lg leading-relaxed max-w-2xl">
					La Artificial Intelligence Society (AIS) se consolida como el organismo científico y profesional referente en la investigación, desarrollo y aplicación ética de la inteligencia artificial. Nuestra organización reúne a mentes brillantes del sector académico e industrial para impulsar el ecosistema tecnológico nacional con estándares globales de excelencia.
				</p>
				<blockquote class="border-l-2 border-cyan-400 pl-4 py-1">
					<p class="text-gray-300 italic font-mono text-sm tracking-wide">
						— Rigurosidad, Ética y Desarrollo.
					</p>
				</blockquote>
			</div>

			<!-- Hero Right (Mision / Vision Cards) -->
			<div class="lg:col-span-5 flex flex-col space-y-6">
				<!-- Mision Card -->
				<div class="p-8 rounded-2xl bg-gray-900/40 border border-gray-800/80 backdrop-blur-md relative overflow-hidden group hover:border-blue-500/30 transition-all duration-300">
					<div class="absolute top-0 right-0 w-24 h-24 bg-blue-500/5 rounded-full blur-xl group-hover:bg-blue-500/10 transition-colors duration-300"></div>
					<div class="flex gap-4">
						<div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center flex-shrink-0 text-blue-400 group-hover:scale-110 transition-transform duration-300">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-2">Misión</h3>
							<p class="text-gray-400 text-sm leading-relaxed">
								Promover el avance y la democratización del conocimiento en Inteligencia Artificial, fomentando la investigación de alto impacto y la formación de profesionales capaces de resolver desafíos complejos en beneficio de la sociedad peruana.
							</p>
						</div>
					</div>
				</div>

				<!-- Vision Card -->
				<div class="p-8 rounded-2xl bg-gray-900/40 border border-gray-800/80 backdrop-blur-md relative overflow-hidden group hover:border-cyan-500/30 transition-all duration-300">
					<div class="absolute top-0 right-0 w-24 h-24 bg-cyan-500/5 rounded-full blur-xl group-hover:bg-cyan-500/10 transition-colors duration-300"></div>
					<div class="flex gap-4">
						<div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center flex-shrink-0 text-cyan-400 group-hover:scale-110 transition-transform duration-300">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-2">Visión</h3>
							<p class="text-gray-400 text-sm leading-relaxed">
								Ser el epicentro de la innovación tecnológica en América Latina, transformando al Perú en un hub regional de excelencia científica que lidera el desarrollo ético y sostenible de sistemas inteligentes.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Areas Section -->
		<section class="max-w-7xl mx-auto px-6 py-20 border-t border-gray-800/40">
			<div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
				<span class="text-xs font-bold tracking-widest text-blue-400 uppercase">Nuestras Áreas</span>
				<h2 class="text-3xl md:text-4xl font-extrabold text-white">Explora nuestras áreas de trabajo</h2>
				<div class="w-24 h-1 bg-gradient-to-r from-blue-600 to-cyan-400 mx-auto rounded-full"></div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				<!-- Area 1 -->
				<div class="p-8 rounded-2xl bg-[#0F1423]/40 border border-gray-800/80 backdrop-blur-md group hover:-translate-y-1 hover:border-blue-500/40 hover:shadow-lg hover:shadow-blue-500/5 transition-all duration-300 flex flex-col justify-between">
					<div class="space-y-4">
						<div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 9.172V5L8 4z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Investigación e Innovación</h3>
						<p class="text-gray-400 text-sm leading-relaxed">
							Desarrollamos proyectos de vanguardia y publicaciones científicas que expanden los límites del estado del arte en modelos generativos y predictivos.
						</p>
					</div>
				</div>

				<!-- Area 2 -->
				<div class="p-8 rounded-2xl bg-[#0F1423]/40 border border-gray-800/80 backdrop-blur-md group hover:-translate-y-1 hover:border-cyan-500/40 hover:shadow-lg hover:shadow-cyan-500/5 transition-all duration-300 flex flex-col justify-between">
					<div class="space-y-4">
						<div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors">Ética y Gobernanza de IA</h3>
						<p class="text-gray-400 text-sm leading-relaxed">
							Definimos marcos normativos y principios éticos para asegurar que los sistemas de IA operen con transparencia, justicia y responsabilidad social.
						</p>
					</div>
				</div>

				<!-- Area 3 -->
				<div class="p-8 rounded-2xl bg-[#0F1423]/40 border border-gray-800/80 backdrop-blur-md group hover:-translate-y-1 hover:border-blue-500/40 hover:shadow-lg hover:shadow-blue-500/5 transition-all duration-300 flex flex-col justify-between">
					<div class="space-y-4">
						<div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Educación y Capacitación</h3>
						<p class="text-gray-400 text-sm leading-relaxed">
							Formación especializada para dotar a la próxima generación de ingenieros y científicos de sólidas bases técnicas y de investigación.
						</p>
					</div>
				</div>

				<!-- Area 4 -->
				<div class="p-8 rounded-2xl bg-[#0F1423]/40 border border-gray-800/80 backdrop-blur-md group hover:-translate-y-1 hover:border-cyan-500/40 hover:shadow-lg hover:shadow-cyan-500/5 transition-all duration-300 flex flex-col justify-between">
					<div class="space-y-4">
						<div class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors">Vinculación Institucional</h3>
						<p class="text-gray-400 text-sm leading-relaxed">
							Alianzas estratégicas con gobiernos, universidades de primer nivel y la empresa privada para cocrear proyectos y transferir conocimiento de IA.
						</p>
					</div>
				</div>

				<!-- Area 5 -->
				<div class="p-8 rounded-2xl bg-[#0F1423]/40 border border-gray-800/80 backdrop-blur-md group hover:-translate-y-1 hover:border-blue-500/40 hover:shadow-lg hover:shadow-blue-500/5 transition-all duration-300 flex flex-col justify-between">
					<div class="space-y-4">
						<div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
							</svg>
						</div>
						<h3 class="text-xl font-bold text-white group-hover:text-blue-400 transition-colors">Comunicación y Difusión</h3>
						<p class="text-gray-400 text-sm leading-relaxed">
							Divulgación científica rigurosa pero accesible para educar y desmitificar la inteligencia artificial en la sociedad peruana.
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Call to Action Section -->
		<section class="max-w-7xl mx-auto px-6 py-20">
			<div class="relative rounded-3xl overflow-hidden bg-gradient-to-r from-blue-900/60 to-cyan-900/60 border border-blue-500/20 p-12 lg:p-20 text-center space-y-8 backdrop-blur-md shadow-2xl">
				<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-500/10 via-transparent to-transparent -z-10"></div>
				<h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white tracking-tight">
					Únete a la élite científica del país.
				</h2>
				<p class="text-gray-300 text-lg max-w-xl mx-auto leading-relaxed">
					Buscamos mentes apasionadas y rigurosas que deseen marcar un hito en la investigación de la Inteligencia Artificial en el Perú.
				</p>
				<div>
					<a href="/call" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-[#0B0F19] bg-gradient-to-r from-blue-400 to-cyan-300 rounded-xl hover:from-blue-500 hover:to-cyan-400 focus:ring-4 focus:ring-blue-800 transition-all duration-300 shadow-lg shadow-blue-500/10 transform hover:scale-105">
						Ver Convocatorias
					</a>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="bg-gray-950/80 border-t border-gray-900 py-16">
		<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 text-sm text-gray-400">
			<!-- Column 1 -->
			<div class="space-y-4">
				<span class="font-bold text-white text-lg tracking-wider">AIS</span>
				<p class="leading-relaxed">
					Impulsando el ecosistema de IA en el Perú con excelencia científica y compromiso ético.
				</p>
			</div>

			<!-- Column 2 -->
			<div class="space-y-4">
				<span class="font-semibold text-white">Navegación</span>
				<ul class="space-y-2">
					<li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
					<li><a href="/areas" class="hover:text-white transition-colors">Áreas</a></li>
					<li><a href="/projects" class="hover:text-white transition-colors">Proyectos</a></li>
					<li><a href="/call" class="hover:text-white transition-colors">Convocatorias</a></li>
				</ul>
			</div>

			<!-- Column 3 -->
			<div class="space-y-4">
				<span class="font-semibold text-white">Legal</span>
				<ul class="space-y-2">
					<li><a href="/privacy" class="hover:text-white transition-colors">Privacidad</a></li>
					<li><a href="/terms" class="hover:text-white transition-colors">Contacto</a></li>
				</ul>
			</div>

			<!-- Column 4 -->
			<div class="space-y-4">
				<span class="font-semibold text-white">Social</span>
				<div class="flex gap-4">
					<a href="https://linkedin.com" target="_blank" class="w-10 h-10 rounded-lg bg-gray-900 border border-gray-800 flex items-center justify-center text-gray-400 hover:text-white hover:border-blue-500 transition-colors">
						<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
					</a>
					<a href="https://twitter.com" target="_blank" class="w-10 h-10 rounded-lg bg-gray-900 border border-gray-800 flex items-center justify-center text-gray-400 hover:text-white hover:border-blue-400 transition-colors">
						<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
					</a>
				</div>
			</div>
		</div>
		<div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-gray-900 text-center text-xs text-gray-500">
			&copy; 2026 Artificial Intelligence Society. Todos los derechos reservados.
		</div>
	</footer>

</Layout>
