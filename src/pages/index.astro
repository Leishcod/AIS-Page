---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import heroBg from "../assets/hero-bg.webp";
import logoBlanco from "../assets/logo_blanco.webp";
import communityWorkspace from "../assets/community_workspace.png";
import StatsBanner from "../components/home/StatsBanner.astro";
---

<Layout
	title="AIS | Artificial Intelligence Society"
	description="Liderando la vanguardia científica de la inteligencia artificial en el Perú."
>
	<Navbar />

	<main class="relative overflow-hidden">
		<!-- Hero Section 1 (Main Hero) -->
		<section
			class="relative min-h-[90vh] flex flex-col justify-center py-20 lg:py-32 overflow-hidden border-b border-gray-900"
		>
			<!-- Background Image with Overlay -->
			<div class="absolute inset-0 z-0">
				<img
					src={heroBg.src}
					alt="Workspace background"
					class="w-full h-full object-cover opacity-25"
				/>
				<div
					class="absolute inset-0 bg-gradient-to-b from-[#0B0F19]/90 via-[#0B0F19]/80 to-[#0B0F19]"
				>
				</div>
			</div>

			<div
				class="max-w-7xl mx-auto px-6 relative z-10 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center flex-grow"
			>
				<div class="lg:col-span-7 space-y-6">
					<!-- Top Overline / Subtitle (Reference: line indicator with overline text) -->
					<div
						class="flex items-center gap-3 text-xs font-bold tracking-widest text-blue-300 uppercase"
					>
						<span class="w-8 h-[2px] bg-blue-300"></span>
						ARTIFICIAL INTELLIGENCE SOCIETY
					</div>

					<h1
						class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[1.1] tracking-tighter"
					>
						Liderando el avance <br />
						de la <span class="text-blue-300">IA</span>
					</h1>

					<!-- Description Container with detailed specification placeholder -->
					<div class="space-y-2">
						<p
							class="text-gray-400 text-base md:text-lg font-light leading-relaxed max-w-2xl"
						>
							Somos una organización profesional, científica y
							técnica constituida como el organismo regulador y de
							convergencia para profesionales, investigadores,
							ingenieros y académicos en el campo de la
							Inteligencia Artificial en el Perú.
						</p>
					</div>

					<div class="flex flex-wrap gap-4 pt-4">
						<a
							href="#about"
							class="px-8 py-3.5 text-sm font-bold text-gray-950 bg-blue-300 hover:bg-blue-200 rounded-none transition-all transform hover:-translate-y-0.5 hover:shadow-[0_0_25px_rgba(96,165,250,0.8)]"
						>
							CONÓCENOS
						</a>
						<a
							href="/areas"
							class="px-8 py-3.5 text-sm font-bold text-white border border-white bg-transparent rounded-none transition-all transform hover:-translate-y-0.5 hover:text-blue-300 hover:border-blue-300"
						>
							VER ÁREAS
						</a>
					</div>
				</div>
				<div
					class="lg:col-span-5 flex justify-center lg:justify-end py-8"
				>
					<div class="relative flex items-center justify-center">
						<!-- Ambient backlight glow in color #1E4371 -->
						<div
							class="absolute w-64 h-64 bg-[#1E4371] opacity-75 rounded-full blur-3xl top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
						>
						</div>
						<img
							src={logoBlanco.src}
							alt="AIS Logo Blanco"
							class="w-48 md:w-56 lg:w-64 object-contain opacity-95 relative z-10 filter drop-shadow-[0_0_20px_rgba(30,67,113,0.7)]"
						/>
					</div>
				</div>
			</div>

			<!-- Bottom Indicator Bar (Reference: small colored box status indicator) -->
			<div class="max-w-7xl mx-auto px-6 w-full relative z-10 mt-8">
				<div
					class="flex items-center gap-2 text-xs font-bold tracking-widest text-blue-300 uppercase"
				>
					<span class="w-2.5 h-2.5 bg-blue-300 block"></span>
					PERIODO 2026
				</div>
			</div>
		</section>

		<!-- Hero Section 2 (About / Intro Block placed before stats Counter) -->
		<section
			class="relative max-w-7xl mx-auto px-6 py-20 lg:py-28 border-b border-gray-900 z-10 w-full"
		>
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Left Text Block -->
				<div class="lg:col-span-7 space-y-6">
					<!-- Top Overline / Subtitle -->
					<div
						class="flex items-center gap-3 text-xs font-bold tracking-widest text-blue-300 uppercase"
					>
						<span class="w-8 h-[2px] bg-blue-300"></span>
						¿QUÉ ES AIS?
					</div>

					<h2
						class="text-4xl md:text-5xl font-black text-white leading-tight tracking-tighter"
					>
						Una comunidad que impulsa <br />
						la <span class="text-blue-300">IA</span> en el Perú
					</h2>

					<!-- Description Container with detailed specification placeholder -->
					<div class="space-y-3">
						<p
							class="text-gray-400 text-base md:text-lg font-light leading-relaxed max-w-2xl"
						>
							Fundada en Lima por estudiantes de la Universidad
							Nacional de Ingeniería, AIS nació para promover la
							investigación y difusión de la IA en un contexto de
							acelerada transformación tecnológica. Conectamos la
							excelencia académica con la innovación industrial,
							impulsando el talento local y el desarrollo ético de
							la tecnología para posicionar al Perú como un actor
							clave en la región.
						</p>
					</div>
				</div>

				<!-- Right Image Block with Overlay (Reference: red-blend image layout in blue) -->
				<div class="lg:col-span-5 flex justify-center lg:justify-end">
					<div
						class="relative overflow-hidden group aspect-[4/3] w-full max-w-lg lg:max-w-none border border-gray-800/80"
					>
						<img
							src={communityWorkspace.src}
							alt="AIS Community Research Lab"
							class="w-full h-full object-cover grayscale opacity-90 transition-all duration-500 group-hover:scale-105"
						/>
						<!-- Premium blue multiply blending overlay matching reference image style -->
						<div
							class="absolute inset-0 bg-blue-950/40 mix-blend-multiply pointer-events-none"
						>
						</div>
						<div
							class="absolute inset-0 bg-gradient-to-t from-[#0B0F19] via-transparent to-transparent opacity-80 pointer-events-none"
						>
						</div>
					</div>
				</div>
			</div>
		</section>

		<StatsBanner />

		<!-- Misión & Visión Section -->
		<section
			id="about"
			class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-2 gap-12 border-t border-gray-800/40"
		>
			<!-- Misión Panel -->
			<div
				class="p-8 md:p-12 rounded-3xl bg-gray-900/10 border border-gray-800/80 backdrop-blur-md flex flex-col justify-between hover:border-blue-500/20 transition-all duration-300"
			>
				<div>
					<div
						class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 mb-8"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-6 w-6"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold text-white mb-6">
						Misión
					</h3>
					<p class="text-gray-300 leading-relaxed text-base">
						Liderar el avance global de la inteligencia artificial y
						la competencia de sus profesionales; conectando a la
						comunidad para intercambiar conocimientos técnicos,
						establecer los más altos estándares éticos y
						científicos, y garantizar que la tecnología se
						desarrolle para el beneficio, bienestar y equidad de la
						humanidad.
					</p>
				</div>
			</div>

			<!-- Visión Panel -->
			<div
				class="p-8 md:p-12 rounded-3xl bg-gray-900/10 border border-gray-800/80 backdrop-blur-md flex flex-col justify-between hover:border-cyan-500/20 transition-all duration-300"
			>
				<div>
					<div
						class="w-12 h-12 rounded-xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 mb-8"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							class="h-6 w-6"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
							></path>
						</svg>
					</div>
					<h3 class="text-2xl md:text-3xl font-bold text-white mb-6">
						Visión
					</h3>
					<p class="text-gray-300 leading-relaxed text-base">
						Ser reconocida como una organización profesional de
						referencia en inteligencia artificial, estableciendo
						altos estándares de práctica, investigación y ética en
						el campo, con especial vocación de servicio en el Perú
						y, conforme crezca de manera sostenida, en América
						Latina y el mundo en desarrollo.
					</p>
				</div>
			</div>
		</section>

		<!-- Proyectos Destacados Section -->
		<section
			class="max-w-7xl mx-auto px-6 py-20 border-t border-gray-800/40"
		>
			<div
				class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 gap-4"
			>
				<div>
					<span
						class="text-xs font-bold tracking-widest text-blue-400 uppercase"
						>Trabajo Científico</span
					>
					<h2
						class="text-3xl md:text-4xl font-extrabold text-white mt-2"
					>
						Proyectos Destacados
					</h2>
				</div>
				<a
					href="/projects"
					class="inline-flex items-center gap-2 text-sm font-semibold text-blue-400 hover:text-blue-300 transition-colors"
				>
					Ver todos los proyectos
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-4 w-4"
						fill="none"
						viewBox="0 0 24 24"
						stroke="currentColor"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M9 5l7 7-7 7"></path>
					</svg>
				</a>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
				<!-- Project 1 (Large Grid - spans 2 columns on lg) -->
				<div
					class="lg:col-span-2 p-8 md:p-10 rounded-3xl bg-[#0F1423]/30 border border-gray-800/80 backdrop-blur-md group hover:border-blue-500/30 transition-all duration-300 flex flex-col justify-between"
				>
					<div>
						<span
							class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-blue-500/10 text-blue-400 mb-6"
							>Machine Learning</span
						>
						<h3
							class="text-2xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors"
						>
							Neural Odyssey: Optimización Industrial
						</h3>
						<p
							class="text-gray-400 leading-relaxed text-sm max-w-xl"
						>
							Implementación de arquitectura Transformer para la
							optimización de procesos de manufactura, permitiendo
							un 28% más de eficiencia en plantas automatizadas.
						</p>
					</div>
					<div
						class="mt-8 pt-6 border-t border-gray-850 flex items-center justify-between"
					>
						<span class="text-xs text-gray-500"
							>Publicado: Enero 2026</span
						>
						<a
							href="/projects"
							class="text-xs font-bold text-white group-hover:underline"
							>Leer Caso de Estudio →</a
						>
					</div>
				</div>

				<!-- Small Projects Column -->
				<div class="flex flex-col gap-6">
					<!-- Small Project 1 -->
					<div
						class="p-6 rounded-2xl bg-[#0F1423]/25 border border-gray-800/80 hover:border-blue-500/20 transition-all duration-300"
					>
						<h4 class="text-base font-bold text-white mb-2">
							Framework Ético 1.0
						</h4>
						<p class="text-gray-400 text-xs leading-relaxed">
							Lineamientos de gobernanza para el desarrollo
							responsable de la inteligencia artificial.
						</p>
					</div>

					<!-- Small Project 2 -->
					<div
						class="p-6 rounded-2xl bg-[#0F1423]/25 border border-gray-800/80 hover:border-blue-500/20 transition-all duration-300"
					>
						<h4 class="text-base font-bold text-white mb-2">
							IA en Salud Pública
						</h4>
						<p class="text-gray-400 text-xs leading-relaxed">
							Modelos de detección temprana de anomalías
							pulmonares en imágenes médicas utilizando CNNs.
						</p>
					</div>

					<!-- Small Project 3 -->
					<div
						class="p-6 rounded-2xl bg-[#0F1423]/25 border border-gray-800/80 hover:border-blue-500/20 transition-all duration-300"
					>
						<h4 class="text-base font-bold text-white mb-2">
							Uso de Redes Clónicas
						</h4>
						<p class="text-gray-400 text-xs leading-relaxed">
							Investigación de transferencia de aprendizaje para
							optimizar modelos de lenguaje en español.
						</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
