---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import heroBg from "../assets/hero-bg.webp";
import logoBlanco from "../assets/logo_blanco.webp";
import communityWorkspace from "../assets/community_workspace.png";
import StatsBanner from "../components/home/StatsBanner.astro";
---

<Layout
	title="AIS | Artificial Intelligence Society"
	description="Liderando la vanguardia científica de la inteligencia artificial en el Perú."
>
	<Navbar />

	<main class="relative overflow-hidden">
		<!-- Hero Section 1 (Main Hero) -->
		<section
			class="relative min-h-[90vh] flex flex-col justify-center py-20 lg:py-32 overflow-hidden border-b border-gray-900"
		>
			<!-- Background Image with Overlay -->
			<div class="absolute inset-0 z-0">
				<img
					src={heroBg.src}
					alt="Workspace background"
					class="w-full h-full object-cover opacity-25"
				/>
				<div
					class="absolute inset-0 bg-gradient-to-b from-[#0B0F19]/90 via-[#0B0F19]/80 to-[#0B0F19]"
				>
				</div>
			</div>

			<div
				class="max-w-7xl mx-auto px-6 relative z-10 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 items-center flex-grow"
			>
				<div class="lg:col-span-7 space-y-6">
					<!-- Top Overline / Subtitle (Reference: line indicator with overline text) -->
					<div
						class="flex items-center gap-3 text-xs font-bold tracking-widest text-blue-300 uppercase"
					>
						<span class="w-8 h-[2px] bg-blue-300"></span>
						ARTIFICIAL INTELLIGENCE SOCIETY
					</div>

					<h1
						class="text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[1.1] tracking-tighter"
					>
						Liderando el avance <br />
						de la <span class="text-blue-300">IA</span>
					</h1>

					<!-- Description Container with detailed specification placeholder -->
					<div class="space-y-2">
						<p
							class="text-gray-400 text-base md:text-lg font-light leading-relaxed max-w-2xl"
						>
							Somos una organización profesional, científica y
							técnica constituida como el organismo regulador y de
							convergencia para profesionales, investigadores,
							ingenieros y académicos en el campo de la
							Inteligencia Artificial en el Perú.
						</p>
					</div>

					<div class="flex flex-wrap gap-4 pt-4">
						<a
							href="#about"
							class="px-8 py-3.5 text-sm font-bold text-gray-950 bg-blue-300 hover:bg-blue-200 rounded-none transition-all transform hover:-translate-y-0.5 hover:shadow-[0_0_25px_rgba(96,165,250,0.8)]"
						>
							CONÓCENOS
						</a>
						<a
							href="/areas"
							class="px-8 py-3.5 text-sm font-bold text-white border border-white bg-transparent rounded-none transition-all transform hover:-translate-y-0.5 hover:text-blue-300 hover:border-blue-300"
						>
							VER ÁREAS
						</a>
					</div>
				</div>
				<div
					class="lg:col-span-5 flex justify-center lg:justify-end py-8"
				>
					<div class="relative flex items-center justify-center">
						<!-- Ambient backlight glow in color #1E4371 -->
						<div
							class="absolute w-64 h-64 bg-[#1E4371] opacity-75 rounded-full blur-3xl top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"
						>
						</div>
						<img
							src={logoBlanco.src}
							alt="AIS Logo Blanco"
							class="w-48 md:w-56 lg:w-64 object-contain opacity-95 relative z-10 filter drop-shadow-[0_0_20px_rgba(30,67,113,0.7)]"
						/>
					</div>
				</div>
			</div>

			<!-- Bottom Indicator Bar (Reference: small colored box status indicator) -->
			<div class="max-w-7xl mx-auto px-6 w-full relative z-10 mt-8">
				<div
					class="flex items-center gap-2 text-xs font-bold tracking-widest text-blue-300 uppercase"
				>
					<span class="w-2.5 h-2.5 bg-blue-300 block"></span>
					PERIODO 2026
				</div>
			</div>
		</section>

		<!-- Hero Section 2 (About / Intro Block placed before stats Counter) -->
		<section
			class="relative max-w-7xl mx-auto px-6 py-20 lg:py-28 border-b border-gray-900 z-10 w-full"
		>
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
				<!-- Left Text Block -->
				<div class="lg:col-span-7 space-y-6">
					<!-- Top Overline / Subtitle -->
					<div
						class="flex items-center gap-3 text-xs font-bold tracking-widest text-blue-300 uppercase"
					>
						<span class="w-8 h-[2px] bg-blue-300"></span>
						¿QUÉ ES AIS?
					</div>

					<h2
						class="text-4xl md:text-5xl font-black text-white leading-tight tracking-tighter"
					>
						Una comunidad que impulsa <br />
						la <span class="text-blue-300">IA</span>
					</h2>

					<!-- Description Container with detailed specification placeholder -->
					<div class="space-y-3">
						<p
							class="text-gray-400 text-base md:text-lg font-light leading-relaxed max-w-2xl"
						>
							Fundada en Lima por estudiantes de la Universidad
							Nacional de Ingeniería, AIS nació para promover la
							investigación y difusión de la IA en un contexto de
							acelerada transformación tecnológica. Conectamos la
							excelencia académica con la innovación industrial,
							impulsando el talento local y el desarrollo ético de
							la tecnología para posicionar al Perú como un actor
							clave en la región.
						</p>
					</div>
				</div>

				<!-- Right Image Block with Overlay (Reference: red-blend image layout in blue) -->
				<div class="lg:col-span-5 flex justify-center lg:justify-end">
					<div
						class="relative overflow-hidden group aspect-[4/3] w-full max-w-lg lg:max-w-none border border-gray-800/80"
					>
						<img
							src={communityWorkspace.src}
							alt="AIS Community Research Lab"
							class="w-full h-full object-cover grayscale opacity-90 transition-all duration-500 group-hover:scale-105"
						/>
						<!-- Premium blue multiply blending overlay matching reference image style -->
						<div
							class="absolute inset-0 bg-blue-950/40 mix-blend-multiply pointer-events-none"
						>
						</div>
						<div
							class="absolute inset-0 bg-gradient-to-t from-[#0B0F19] via-transparent to-transparent opacity-80 pointer-events-none"
						>
						</div>
					</div>
				</div>
			</div>
		</section>

		<StatsBanner />

		<!-- Construction Banner -->
		<div
			class="py-16 md:py-24 flex flex-col items-center justify-center gap-3 relative z-10"
		>
			<div
				class="flex items-center gap-2 text-xs font-bold tracking-widest text-blue-300 uppercase"
			>
				<span class="relative flex h-2 w-2">
					<span
						class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
					></span>
					<span
						class="relative inline-flex rounded-full h-2 w-2 bg-blue-300"
					></span>
				</span>
				PÁGINA EN CONSTRUCCIÓN
			</div>
			<p class="text-xs text-gray-500 font-medium">Seguimos diseñando</p>
		</div>
	</main>

	<Footer />
</Layout>
