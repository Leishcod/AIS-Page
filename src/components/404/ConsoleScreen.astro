---

<!-- AI Glitch Console Screen -->
<div
	class="w-full max-w-lg bg-[#070a13]/90 border border-blue-500/20 rounded-xl py-8 px-6 md:px-8 text-left font-mono text-[12px] md:text-[14px] text-blue-300 shadow-[0_0_50px_rgba(96,165,250,0.1)] relative overflow-hidden group hover:border-blue-500/30 transition-all duration-300"
	style="margin-bottom: 4rem !important;"
>
	<!-- Scanline effect overlay -->
	<div
		class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(0,0,0,0.25)_50%),linear-gradient(90deg,rgba(255,0,0,0.06),rgba(0,255,0,0.02),rgba(0,0,255,0.06))] bg-[size:100%_4px,3px_100%] pointer-events-none opacity-45"
	>
	</div>

	<!-- Título Top de fuente MONO -->
	<div class="flex items-center justify-center pb-2 mb-6 relative z-10">
		<span
			class="text-[24px] text-gray-500 uppercase tracking-widest font-mono font-semibold"
			>Console v1.0.4</span
		>
	</div>

	<!-- Console lines -->
	<div class="space-y-4 relative z-10 font-mono">
		<p class="text-[15px] text-blue-300/80 pl-4">
			&gt; PING: TRANSMISSION_FAILED (Host Desconocido)
		</p>
		<p class="text-[15px] text-blue-300/80 pl-4">
			&gt; ESTADO: RUTA INEXISTENTE O ENLACE ROTO [ERROR 404]
		</p>
		<p
			class="text-[15px] text-green-400 animate-pulse pl-4 flex items-center gap-1.5"
		>
			<span class="text-green-500"
				>&gt;&gt; SUGERENCIA: Regresar al núcleo central. <span
					class="w-1.5 h-3.5 bg-green-400 inline-block align-middle ml-1"
				></span></span
			>
		</p>
	</div>
</div>
