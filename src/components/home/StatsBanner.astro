---
// Expanded coordinate system to cover wider aspect ratio
const hexagons = [
	// Col 1 (x = 20)
	{ x: 20, y: 20, filled: false },
	{ x: 20, y: 56, filled: true },
	{ x: 20, y: 92, filled: false },
	{ x: 20, y: 128, filled: false },
	// Col 2 (x = 44)
	{ x: 44, y: 38, filled: false },
	{ x: 44, y: 74, filled: true },
	{ x: 44, y: 110, filled: false },
	{ x: 44, y: 146, filled: true },
	// Col 3 (x = 68)
	{ x: 68, y: 20, filled: true },
	{ x: 68, y: 56, filled: false },
	{ x: 68, y: 92, filled: false },
	{ x: 68, y: 128, filled: true },
	// Col 4 (x = 92)
	{ x: 92, y: 38, filled: false },
	{ x: 92, y: 74, filled: true },
	{ x: 92, y: 110, filled: false },
	{ x: 92, y: 146, filled: false },
	// Col 5 (x = 116)
	{ x: 116, y: 20, filled: false },
	{ x: 116, y: 56, filled: true },
	{ x: 116, y: 92, filled: false },
	{ x: 116, y: 128, filled: false },
	// Col 6 (x = 140)
	{ x: 140, y: 38, filled: true },
	{ x: 140, y: 74, filled: false },
	{ x: 140, y: 110, filled: false },
	{ x: 140, y: 146, filled: false },
	// Col 7 (x = 164)
	{ x: 164, y: 20, filled: false },
	{ x: 164, y: 56, filled: true },
	{ x: 164, y: 92, filled: false },
	{ x: 164, y: 128, filled: true },
	// Col 8 (x = 188)
	{ x: 188, y: 38, filled: false },
	{ x: 188, y: 74, filled: true },
	{ x: 188, y: 110, filled: false },
	{ x: 188, y: 146, filled: false },
	// Col 9 (x = 212)
	{ x: 212, y: 20, filled: true },
	{ x: 212, y: 56, filled: false },
	{ x: 212, y: 92, filled: false },
	{ x: 212, y: 128, filled: false },
];
---

<section
	class="bg-[#233B4E] py-16 md:py-20 relative z-10 border-y border-gray-900/60 overflow-hidden"
>
	<!-- Left Hexagons Background decoration (Dense Honeycomb Network) -->
	<div
		class="absolute top-0 left-0 right-0 bottom-auto md:bottom-0 md:right-auto h-24 md:h-full w-full md:w-[50%] pointer-events-none overflow-hidden flex items-start pl-0 z-0 -translate-y-6 md:translate-y-0"
	>
		<div
			class="w-full h-full md:w-80 md:h-full lg:w-[560px] animate-hex-left select-none md:-ml-12 md:-ml-16 lg:-ml-20"
		>
			<svg
				class="w-full h-full text-cyan-300"
				viewBox="0 0 230 170"
				preserveAspectRatio="xMidYMid slice"
				fill="none"
				stroke="currentColor"
				stroke-linejoin="round"
			>
				<defs>
					<filter
						id="hex-glow"
						x="-30%"
						y="-30%"
						width="160%"
						height="160%"
					>
						<feGaussianBlur stdDeviation="4" result="blur"
						></feGaussianBlur>
						<feMerge>
							<feMergeNode in="blur"></feMergeNode>
							<feMergeNode in="SourceGraphic"></feMergeNode>
						</feMerge>
					</filter>
				</defs>
				{
					hexagons.map((hex, index) => {
						const points = `${hex.x},${hex.y - 18} ${hex.x + 16},${hex.y - 9} ${hex.x + 16},${hex.y + 9} ${hex.x},${hex.y + 18} ${hex.x - 16},${hex.y + 9} ${hex.x - 16},${hex.y - 9}`;
						const patternClass = `hex-pattern-${(index % 12) + 1}`;
						return (
							<polygon
								points={points}
								class={`hex-poly ${hex.filled ? "hex-filled" : "hex-outline"} ${patternClass}`}
								filter={
									hex.filled ? "url(#hex-glow)" : undefined
								}
								style={`transform-origin: ${hex.x}px ${hex.y}px;`}
							/>
						);
					})
				}
			</svg>
		</div>
		<!-- Gradient fade-out mask towards the center -->
		<div
			class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-transparent to-[#233B4E] w-full h-full"
		>
		</div>
	</div>

	<!-- Right Hexagons Background decoration (Dense Honeycomb Network, mirrored) -->
	<div
		class="absolute bottom-0 left-0 right-0 top-auto md:top-0 md:left-auto h-24 md:h-full w-full md:w-[50%] pointer-events-none overflow-hidden flex items-end z-0 scale-y-[-1] md:scale-y-[1] md:scale-x-[-1] translate-y-8 md:translate-y-0"
	>
		<div
			class="w-full h-full md:w-80 md:h-full lg:w-[560px] animate-hex-right select-none md:-ml-12 md:-ml-16 lg:-ml-20"
		>
			<svg
				class="w-full h-full text-cyan-300"
				viewBox="0 0 230 170"
				preserveAspectRatio="xMidYMid slice"
				fill="none"
				stroke="currentColor"
				stroke-linejoin="round"
			>
				<defs>
					<filter
						id="hex-glow"
						x="-30%"
						y="-30%"
						width="160%"
						height="160%"
					>
						<feGaussianBlur stdDeviation="4" result="blur"
						></feGaussianBlur>
						<feMerge>
							<feMergeNode in="blur"></feMergeNode>
							<feMergeNode in="SourceGraphic"></feMergeNode>
						</feMerge>
					</filter>
				</defs>
				{
					hexagons.map((hex, index) => {
						const points = `${hex.x},${hex.y - 18} ${hex.x + 16},${hex.y - 9} ${hex.x + 16},${hex.y + 9} ${hex.x},${hex.y + 18} ${hex.x - 16},${hex.y + 9} ${hex.x - 16},${hex.y - 9}`;
						const patternClass = `hex-pattern-${(index % 12) + 1}`;
						return (
							<polygon
								points={points}
								class={`hex-poly ${hex.filled ? "hex-filled" : "hex-outline"} ${patternClass}`}
								filter={
									hex.filled ? "url(#hex-glow)" : undefined
								}
								style={`transform-origin: ${hex.x}px ${hex.y}px;`}
							/>
						);
					})
				}
			</svg>
		</div>
		<!-- Gradient fade-out mask towards the center -->
		<div
			class="absolute inset-0 bg-gradient-to-b md:bg-gradient-to-r from-transparent to-[#233B4E] w-full h-full"
		>
		</div>
	</div>

	<!-- Title Block (Ref: Nuestras cifras) -->
	<div
		class="max-w-5xl mx-auto px-6 text-center mb-10 md:mb-20 relative z-10"
	>
		<h2
			class="text-[46px] md:text-[68px] font-black tracking-tight text-blue-300 leading-tight text-glow-blue"
		>
			Nuestras Cifras
		</h2>
	</div>

	<div
		class="max-w-5xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 divide-y divide-white/10 md:divide-y-0 md:divide-x divide-white/10 text-center items-center text-white relative z-10"
	>
		<div class="space-y-3 py-6 md:py-0">
			<div
				class="text-[46px] md:text-[68px] font-black tracking-tight text-white leading-none mb-1 text-glow-blue"
			>
				+<span class="stat-number" data-target="67">0</span>
			</div>
			<div
				class="text-[11px] md:text-[13px] font-bold tracking-widest text-blue-100/80 uppercase"
			>
				Miembros Activos
			</div>
		</div>
		<div class="space-y-3 py-6 md:py-0">
			<div
				class="text-[46px] md:text-[68px] font-black tracking-tight text-white leading-none mb-1 text-glow-blue"
			>
				+<span class="stat-number" data-target="67">0</span>
			</div>
			<div
				class="text-[11px] md:text-[13px] font-bold tracking-widest text-blue-100/80 uppercase"
			>
				Proyectos Completados
			</div>
		</div>
		<div class="space-y-3 py-6 md:py-0">
			<div
				class="text-[46px] md:text-[68px] font-black tracking-tight text-white leading-none mb-1 text-glow-blue"
			>
				+<span class="stat-number" data-target="67">0</span>
			</div>
			<div
				class="text-[11px] md:text-[13px] font-bold tracking-widest text-blue-100/80 uppercase"
			>
				Eventos Realizados
			</div>
		</div>
	</div>
</section>

<script>
	// Animation for stats counters
	function initStatsAnimation() {
		const statElements = document.querySelectorAll(".stat-number");

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const target = entry.target as HTMLElement;
						const targetValue = parseInt(
							target.getAttribute("data-target") || "0",
							10,
						);

						if (targetValue === 0) {
							target.textContent = "0";
							return;
						}

						const duration = 1500; // 1.5 seconds
						const startTime = performance.now();

						function updateNumber(now: number) {
							const progress = Math.min(
								(now - startTime) / duration,
								1,
							);
							const easeProgress = progress * (2 - progress); // easeOutQuad
							const currentValue = Math.floor(
								easeProgress * targetValue,
							);

							target.textContent = currentValue.toString();

							if (progress < 1) {
								requestAnimationFrame(updateNumber);
							} else {
								target.textContent = targetValue.toString();
							}
						}

						requestAnimationFrame(updateNumber);
						observer.unobserve(target);
					}
				});
			},
			{ threshold: 0.2 },
		);

		statElements.forEach((el) => observer.observe(el));
	}

	// Run after page load
	initStatsAnimation();
	document.addEventListener("astro:page-load", initStatsAnimation);
</script>

<style>
	.animate-hex-left {
		/* Stationary position */
	}
	.animate-hex-right {
		/* Stationary position */
	}

	/* --- MOBILE STYLES (Default / Mobile-First) --- */

	.hex-poly {
		stroke: #67e8f9; /* cyan-300 */
		fill: #22d3ee; /* cyan-400 */
		stroke-linejoin: round;
		will-change:
			fill-opacity, stroke-opacity, stroke-width, filter, transform;
		filter: none !important; /* Disable SVG attribute filter on mobile */
		transform: rotate(90deg); /* Flat-topped horizontally on mobile */
	}

	/* Dynamic cycle animation (silhouette <-> glow filled) */
	@keyframes glow-cycle {
		0%,
		100% {
			fill-opacity: 0;
			stroke-opacity: 0.12;
			stroke-width: 1.2px;
		}
		50% {
			fill-opacity: 0.35;
			stroke-opacity: 1;
			stroke-width: 2px;
			filter: drop-shadow(0 0 5px rgba(34, 211, 238, 0.7));
		}
	}

	/* 12 Interleaved patterns for mobile */
	.hex-pattern-1 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: 0s;
	}
	.hex-pattern-2 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -1.5s;
	}
	.hex-pattern-3 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -3s;
	}
	.hex-pattern-4 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -4.5s;
	}
	.hex-pattern-5 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -6s;
	}
	.hex-pattern-6 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -7.5s;
	}
	.hex-pattern-7 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -9s;
	}
	.hex-pattern-8 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -10.5s;
	}
	.hex-pattern-9 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -12s;
	}
	.hex-pattern-10 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -13.5s;
	}
	.hex-pattern-11 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -15s;
	}
	.hex-pattern-12 {
		animation: glow-cycle 18s ease-in-out infinite;
		animation-delay: -16.5s;
	}

	/* --- DESKTOP STYLES (Overrides) --- */
	@media (min-width: 768px) {
		.hex-poly {
			transform: rotate(
				0deg
			) !important; /* Pointy-topped vertically on desktop */
		}

		/* Disable mobile glow cycle animation on desktop */
		.hex-pattern-1,
		.hex-pattern-2,
		.hex-pattern-3,
		.hex-pattern-4,
		.hex-pattern-5,
		.hex-pattern-6,
		.hex-pattern-7,
		.hex-pattern-8,
		.hex-pattern-9,
		.hex-pattern-10,
		.hex-pattern-11,
		.hex-pattern-12 {
			animation: pulse-async 5s ease-in-out infinite !important;
		}

		/* Re-apply desktop delay keys for static opacity pulsing */
		.hex-pattern-1 {
			animation-delay: 0.1s !important;
		}
		.hex-pattern-2 {
			animation-delay: 1.3s !important;
		}
		.hex-pattern-3 {
			animation-delay: 0.6s !important;
		}
		.hex-pattern-4 {
			animation-delay: 2.1s !important;
		}
		.hex-pattern-5 {
			animation-delay: 0.9s !important;
		}
		.hex-pattern-6 {
			animation-delay: 2.8s !important;
		}
		.hex-pattern-7 {
			animation-delay: 0.5s !important;
		}
		.hex-pattern-8 {
			animation-delay: 1.7s !important;
		}
		.hex-pattern-9 {
			animation-delay: 1.1s !important;
		}
		.hex-pattern-10 {
			animation-delay: 2.3s !important;
		}
		.hex-pattern-11 {
			animation-delay: 0.8s !important;
		}
		.hex-pattern-12 {
			animation-delay: 1.9s !important;
		}

		/* Restore static filled/outline configurations */
		.hex-filled {
			fill: #22d3ee !important; /* cyan-400 */
			fill-opacity: 0.35 !important;
			stroke: #67e8f9 !important; /* cyan-300 */
			stroke-opacity: 1 !important;
			stroke-width: 2px !important;
			/* SVG filter="url(#hex-glow)" applies here naturally */
		}

		.hex-outline {
			fill: none !important;
			fill-opacity: 0 !important;
			stroke: #67e8f9 !important; /* cyan-300 */
			stroke-opacity: 0.15 !important;
			stroke-width: 1.2px !important;
			filter: none !important; /* Turn off glows for outlines */
		}
	}

	@keyframes pulse-async {
		0%,
		100% {
			opacity: 0.08;
		}
		50% {
			opacity: 0.85;
		}
	}
</style>
