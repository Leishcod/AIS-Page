---
import logoHorizontal from "../assets/logo_horizontal.webp";
---

<footer class="bg-gray-950/80 border-t border-gray-900/60 pt-16 pb-8">
	<div
		class="max-w-7xl mx-auto px-6 flex flex-col lg:flex-row justify-between gap-12 lg:gap-24 text-[15px] text-gray-400"
	>
		<!-- Column 1 -->
		<div class="space-y-4 max-w-sm">
			<div class="flex items-center gap-3">
				<img
					src={logoHorizontal.src}
					alt="AIS Logo"
					class="h-8 object-contain"
				/>
			</div>
			<p class="leading-relaxed">
				Impulsando la frontera de la Inteligencia Artificial a través de
				la investigación rigurosa, la práctica ética y la colaboración
				interdisciplinaria.
			</p>
		</div>

		<!-- Links Columns Wrapper with smaller gap -->
		<div
			class="flex-1 grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-10 lg:gap-12 max-w-xl lg:ml-auto"
		>
			<!-- Column 2 -->
			<div class="space-y-6">
				<span
					class="block font-semibold text-white uppercase tracking-wider text-[14px]"
					>ORGANIZACIÓN</span
				>
				<ul class="space-y-2">
					<li>
						<a
							href="/about"
							class="hover:text-blue-300 transition-colors"
							>Conócenos</a
						>
					</li>
					<li>
						<a
							href="/areas"
							class="hover:text-blue-300 transition-colors"
							>Áreas</a
						>
					</li>
					<li>
						<a
							href="/projects"
							class="hover:text-blue-300 transition-colors"
							>Proyectos</a
						>
					</li>
				</ul>
			</div>

			<!-- Column 3 -->
			<div class="space-y-6">
				<span
					class="block font-semibold text-white uppercase tracking-wider text-[14px]"
					>COMUNIDAD</span
				>
				<ul class="space-y-2">
					<li>
						<a
							href="/events"
							class="hover:text-blue-300 transition-colors"
							>Eventos</a
						>
					</li>
					<li>
						<a
							href="/call"
							class="hover:text-blue-300 transition-colors"
							>Convocatoria</a
						>
					</li>
				</ul>
			</div>

			<!-- Column 4 -->
			<div class="space-y-6">
				<span
					class="block font-semibold text-white uppercase tracking-wider text-[14px]"
					>REDES</span
				>
				<ul class="space-y-2">
					<li>
						<a
							href="https://www.linkedin.com/company/the-aisociety/"
							target="_blank"
							rel="noopener noreferrer"
							class="hover:text-blue-300 transition-colors"
							>Linkedin</a
						>
					</li>
					<li>
						<a
							href="https://www.instagram.com/theais.pe/"
							target="_blank"
							rel="noopener noreferrer"
							class="hover:text-blue-300 transition-colors"
							>Instagram</a
						>
					</li>
				</ul>
			</div>
		</div>
	</div>
	<div
		class="max-w-7xl mx-auto px-6 mt-10 pt-6 border-t border-gray-900/60 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500"
	>
		<div>&copy; 2026 Artificial Intelligence Society</div>
		<div class="flex gap-6">
			<a href="/privacy" class="hover:text-blue-300 transition-colors"
				>Políticas de Privacidad</a
			>
			<a href="/terms" class="hover:text-blue-300 transition-colors"
				>Términos de Servicio</a
			>
		</div>
	</div>
</footer>
