---
import logoHorizontal from "../assets/logo_horizontal.webp";

const currentYear = new Date().getFullYear();

const organizationLinks = [
	{ name: "Conócenos", href: "/about" },
	{ name: "Áreas", href: "/areas" },
	{ name: "Proyectos", href: "/projects" },
];

const communityLinks = [
	{ name: "Eventos", href: "/events" },
	{ name: "Capítulos", href: "/chapters" },
	{ name: "Convocatoria", href: "/call" },
];

const socialLinks = [
	{
		name: "LinkedIn",
		href: "https://www.linkedin.com/company/the-aisociety/",
		icon: `<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>`,
	},
	{
		name: "Instagram",
		href: "https://www.instagram.com/theais.pe/",
		icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204 0.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>`,
	},
];
---

<footer class="bg-gray-950/80 border-t border-gray-900/60 pt-16 pb-8">
	<div
		class="max-w-7xl mx-auto px-6 flex flex-col lg:flex-row justify-between gap-12 lg:gap-24 text-[15px] text-gray-400"
	>
		<!-- Grid content wrapper -->
		<div
			class="w-full grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8 mb-12"
		>
			<!-- Column 1: Brand block (spans more cols, description text is wider, icons below) -->
			<div class="md:col-span-6 lg:col-span-6 space-y-6">
				<div class="flex items-center gap-3">
					<img
						src={logoHorizontal.src}
						alt="AIS Logo"
						class="h-10 object-contain"
					/>
				</div>
				<p class="leading-relaxed text-gray-400 text-[14px] max-w-md">
					Impulsando la frontera de la Inteligencia Artificial a
					través de la investigación rigurosa, la práctica ética y la
					colaboración interdisciplinaria.
				</p>
				<!-- Social Network Icons -->
				<div class="flex items-center gap-4">
					{
						socialLinks.map((item) => (
							<a
								href={item.href}
								target="_blank"
								rel="noopener noreferrer"
								class="w-10 h-10 rounded-lg bg-gray-900/40 border border-gray-800/80 flex items-center justify-center text-gray-400 hover:text-blue-300 hover:border-blue-500/30 hover:bg-blue-500/5 transition-all duration-300"
								aria-label={item.name}
							>
								<svg
									class="w-5 h-5"
									fill="currentColor"
									viewBox="0 0 24 24"
									set:html={item.icon}
								/>
							</a>
						))
					}
				</div>
			</div>

			<!-- Column 2: Organización Links -->
			<div class="md:col-span-3 lg:col-span-3 space-y-6">
				<span
					class="block font-semibold text-white uppercase tracking-wider text-[14px]"
					>ORGANIZACIÓN</span
				>
				<ul class="space-y-4">
					{
						organizationLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="relative flex items-center text-gray-400 hover:text-blue-300 text-[14px] transition-all duration-300 pl-0 hover:pl-4 group"
								>
									<span class="absolute left-0 w-1.5 h-1.5 rounded-full bg-blue-400 opacity-0 group-hover:opacity-100 scale-0 group-hover:scale-100 transition-all duration-300 origin-center shrink-0" />
									<span>{link.name}</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<!-- Column 3: Comunidad Links -->
			<div class="md:col-span-3 lg:col-span-3 space-y-6">
				<span
					class="block font-semibold text-white uppercase tracking-wider text-[14px]"
					>COMUNIDAD</span
				>
				<ul class="space-y-4">
					{
						communityLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="relative flex items-center text-gray-400 hover:text-blue-300 text-[14px] transition-all duration-300 pl-0 hover:pl-4 group"
								>
									<span class="absolute left-0 w-1.5 h-1.5 rounded-full bg-blue-400 opacity-0 group-hover:opacity-100 scale-0 group-hover:scale-100 transition-all duration-300 origin-center shrink-0" />
									<span>{link.name}</span>
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>
	</div>

	<!-- Bottom Section -->
	<div
		class="max-w-7xl mx-auto px-6 mt-10 pt-6 border-t border-gray-900/60 flex flex-col md:flex-row justify-between items-center gap-4 text-[12px] text-gray-500"
	>
		<div>&copy; {currentYear} ARTIFICIAL INTELLIGENCE SOCIETY</div>
		<div class="flex gap-6">
			<a href="/privacy" class="hover:text-blue-300 transition-colors"
				>Políticas de Privacidad</a
			>
			<a href="/terms" class="hover:text-blue-300 transition-colors"
				>Términos de Servicio</a
			>
		</div>
	</div>
</footer>
